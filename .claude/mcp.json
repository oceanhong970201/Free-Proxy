{
  "mcpServers": {
    "fetch": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "mcp-server-fetch"],
      "type": "stdio"
    },
    "playwright": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@playwright/mcp@latest", "--caps=network,storage"],
      "type": "stdio"
    },
    "tavily": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "tavily-mcp@latest"],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      },
      "type": "stdio"
    },
    "telegram-mcp": {
      "command": "uv",
      "args": ["run", "telegram-mcp"],
      "env": {
        "API_ID": "${TELEGRAM_API_ID}",
        "API_HASH": "${TELEGRAM_API_HASH}",
        "SESSION": "${TELEGRAM_SESSION_STRING}"
      },
      "type": "stdio"
    },
    "sqlite": {
      "command": "uvx",
      "args": ["mcp-server-sqlite", "--db-path", "C:\\Users\\win10\\Documents\\Free-Proxy\\nodes.db"],
      "type": "stdio"
    },
    "memory": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@modelcontextprotocol/server-memory"],
      "type": "stdio"
    },
    "github": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "-e", "GITHUB_PERSONAL_ACCESS_TOKEN", "ghcr.io/github/github-mcp-server"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PAT}"
      },
      "type": "stdio"
    },
    "cloudflare-docs": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "mcp-remote", "https://docs.mcp.cloudflare.com/mcp"],
      "type": "stdio"
    },
    "cloudflare-bindings": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "mcp-remote", "https://bindings.mcp.cloudflare.com/mcp"],
      "type": "stdio"
    },
    "cloudflare-builds": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "mcp-remote", "https://builds.mcp.cloudflare.com/mcp"],
      "type": "stdio"
    },
    "cloudflare-observability": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "mcp-remote", "https://observability.mcp.cloudflare.com/mcp"],
      "type": "stdio"
    },
    "cloudflare-browser": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "mcp-remote", "https://browser.mcp.cloudflare.com/mcp"],
      "type": "stdio"
    },
    "cloudflare-logpush": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "mcp-remote", "https://logs.mcp.cloudflare.com/mcp"],
      "type": "stdio"
    },
    "time": {
      "command": "uvx",
      "args": ["mcp-server-time"],
      "type": "stdio"
    }
  }
}
